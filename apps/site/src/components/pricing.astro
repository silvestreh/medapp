---
import { content } from '../content/es';

const { pricing } = content;
---

<section id="precios" class="pricing">
  <div class="container">
    <div class="section-header fade-in">
      <span class="badge">{pricing.badge}</span>
      <h2 class="section-headline">{pricing.headline}</h2>
    </div>

    <div class="pricing-cards">
      {pricing.plans.map((plan) => (
        <div class:list={['plan-card', 'fade-in', { popular: plan.popular }]}>
          <div class="plan-header">
            <div class="plan-name-row">
              <span class="plan-name">{plan.name}</span>
              {plan.popular && <span class="popular-badge">Popular</span>}
            </div>
            <div class="plan-price-row">
              <span class="plan-price">{plan.price}</span>
              <span class="plan-period">{plan.period}</span>
            </div>
            <p class="plan-desc">{plan.description}</p>
          </div>

          <div class="divider"></div>

          <ul class="plan-features">
            {plan.features.map((feature) => (
              <li class="plan-feature">{feature}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .pricing {
    padding: 5rem 0;
  }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .badge {
    display: block;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-teal);
    margin-bottom: 1rem;
  }

  .section-headline {
    font-family: var(--font-serif);
    font-size: clamp(32px, 4vw, 48px);
    font-weight: 400;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--color-black);
  }

  .pricing-cards {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
    max-width: 900px;
    margin: 0 auto;
  }

  .plan-card {
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .plan-card.popular {
    border: 2px solid var(--color-teal);
  }

  .plan-header {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .plan-name-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .plan-name {
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-teal);
  }

  .popular-badge {
    font-size: 14px;
    background: var(--color-teal);
    color: var(--color-black);
    padding: 4px 10px;
    border-radius: 100px;
    font-weight: 500;
  }

  .plan-price-row {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
  }

  .plan-price {
    font-family: var(--font-serif);
    font-size: 56px;
    letter-spacing: -0.03em;
    line-height: 1;
    color: var(--color-black);
  }

  .plan-period {
    font-size: 16px;
    color: var(--color-muted);
  }

  .plan-desc {
    font-size: 16px;
    line-height: 1.5;
    color: var(--color-muted-dark);
  }

  .divider {
    height: 1px;
    background: var(--color-border);
  }

  .plan-features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .plan-feature {
    font-size: 15px;
    line-height: 1.6;
    color: var(--color-body);
    padding-left: 0;
  }

  @media (max-width: 640px) {
    .pricing-cards {
      grid-template-columns: 1fr;
    }

    .plan-price {
      font-size: 44px;
    }
  }
</style>
