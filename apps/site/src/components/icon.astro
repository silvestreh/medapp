---
import { readFileSync } from 'node:fs';
import { createRequire } from 'node:module';
import { resolve, dirname } from 'node:path';

interface Props {
  name: string;
  size?: number;
  weight?: 'regular' | 'bold' | 'light' | 'fill';
  class?: string;
}

const { name, size = 32, weight = 'regular', class: className } = Astro.props;

const require = createRequire(import.meta.url);
const corePath = resolve(dirname(require.resolve('@phosphor-icons/core')), '..');
const iconPath = resolve(corePath, `assets/${weight}/${name}.svg`);
const raw = readFileSync(iconPath, 'utf-8');

// Replace width/height attributes and add our own
const svg = raw
  .replace(/width="[^"]*"/, `width="${size}"`)
  .replace(/height="[^"]*"/, `height="${size}"`)
  .replace('<svg', `<svg class="${className ?? ''}"`)
  .replace(/fill="[^"]*"/g, 'fill="currentColor"');
---

<Fragment set:html={svg} />
