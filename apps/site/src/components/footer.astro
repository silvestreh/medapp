---
import { content } from '../content/es';

interface Props {
  showPricing?: boolean;
}

const { showPricing = false } = Astro.props;
const { nav, footer } = content;
const columns = footer.columns.map((col) => ({
  ...col,
  links: showPricing ? col.links : col.links.filter((l) => l.href !== '/#precios'),
}));
---

<footer class="footer">
  <div class="container">
    <div class="footer-top">
      <div class="footer-brand">
        <span class="logo-text">{nav.logo}</span>
        <p class="tagline">{footer.tagline}</p>
      </div>

      <div class="footer-columns">
        {columns.map((col) => (
          <div class="footer-col">
            <span class="col-title">{col.title}</span>
            {col.links.map((link) => (
              <a href={link.href} class="col-link">{link.label}</a>
            ))}
          </div>
        ))}
      </div>
    </div>

    <div class="footer-bottom">
      <span class="copyright">{footer.copyright}</span>
      <span class="made-in">{footer.madeIn}</span>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding: 4rem 0 0;
    border-top: 1px solid var(--color-border);
  }

  .footer-top {
    display: flex;
    justify-content: space-between;
    gap: 4rem;
    padding-bottom: 3rem;
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    max-width: 240px;
  }

  .logo-text {
    font-family: var(--font-serif);
    font-size: 24px;
    color: var(--color-black);
  }

  .tagline {
    font-size: 14px;
    line-height: 1.6;
    color: var(--color-muted);
    white-space: pre-line;
  }

  .footer-columns {
    display: flex;
    gap: 4rem;
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .col-title {
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-black);
    margin-bottom: 0.25rem;
  }

  .col-link {
    font-size: 14px;
    color: var(--color-muted);
    transition: color 0.2s;
  }

  .col-link:hover {
    color: var(--color-black);
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    padding: 1.5rem 0;
    border-top: 1px solid var(--color-border);
  }

  .copyright, .made-in {
    font-size: 13px;
    color: var(--color-muted);
  }

  @media (max-width: 768px) {
    .footer-top {
      flex-direction: column;
      gap: 2.5rem;
    }

    .footer-columns {
      flex-wrap: wrap;
      gap: 2rem;
    }

    .footer-bottom {
      flex-direction: column;
      gap: 0.5rem;
    }
  }
</style>
