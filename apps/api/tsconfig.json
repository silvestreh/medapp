{
  "compilerOptions": {
    "target": "es2018",
    "module": "commonjs",
    "outDir": "./lib",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "resolveJsonModule": true,
    "composite": true,
    "skipLibCheck": true,
    "jsx": "react",
    "types": ["node", "mocha"]
  },
  "include": ["src", "test"],
  "exclude": ["scripts", "data", "lib"]
}
