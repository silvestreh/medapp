{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "providers": ["python"],
      "phases": {
        "setup": {
          "aptPkgs": [
            "libgl1",
            "libglib2.0-0",
            "libxcb1",
            "libx11-6",
            "libxext6",
            "libsm6",
            "libice6",
            "libxrender1",
            "ffmpeg"
          ]
        }
      }
    },
    "watchPatterns": ["apps/face-compare/**"]
  },
  "deploy": {
    "startCommand": "uvicorn main:app --host 0.0.0.0 --port ${PORT:-8000}",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
