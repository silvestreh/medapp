{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "providers": ["python"]
    },
    "buildCommand": "cd apps/face-compare && pip install -r requirements.txt",
    "watchPatterns": ["apps/face-compare/**"]
  },
  "deploy": {
    "startCommand": "cd apps/face-compare && uvicorn main:app --host 0.0.0.0 --port ${PORT:-8000}",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
