# Database
DB_URL=postgres://user:password@localhost:5432/athelas_api
ENCRYPTION_KEY=your-encryption-key-here

# Server
FHIR_PORT=3040

# Authentication (shared secret from DNSIS registration)
FHIR_JWT_SECRET=your-dnsis-jwt-secret

# Local development only — skip JWT auth so you can browse in the browser
# FHIR_SKIP_AUTH=true

# SSL (optional, for production)
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true
