{
  "name": "athelas-kyc",
  "version": "1.0.0",
  "description": "Athelas KYC API - Identity verification session coordination",
  "main": "lib/",
  "scripts": {
    "build": "shx rm -rf lib/ && tsc && shx mkdir -p lib/mobile-page && shx cp src/mobile-page/template.pug lib/mobile-page/template.pug && shx cp src/mobile-page/error.pug lib/mobile-page/error.pug && pnpm run build:css && pnpm run build:client && pnpm run build:widget && pnpm run build:admin",
    "build:client": "esbuild src/mobile-page/client/index.tsx --bundle --minify --outfile=public/app.js --platform=browser --target=es2020 --jsx=automatic",
    "build:css": "tailwindcss -i src/mobile-page/tailwind.css -o public/styles.css --minify",
    "build:widget": "pnpm run build:widget-css && pnpm run build:widget-client",
    "build:widget-css": "tailwindcss -i src/widget-page/tailwind.css -o public/widget-styles.css --minify",
    "build:widget-client": "node scripts/build-widget.mjs",
    "build:admin": "pnpm run build:admin-css && pnpm run build:admin-client",
    "build:admin-css": "tailwindcss -i src/admin-page/tailwind.css -o public/admin-styles.css --minify",
    "build:admin-client": "node scripts/build-admin.mjs",
    "dev": "concurrently \"ts-node-dev --no-notify src/\" \"pnpm run watch:client\" \"pnpm run watch:widget\"",
    "watch:client": "esbuild src/mobile-page/client/index.tsx --bundle --outfile=public/app.js --platform=browser --target=es2020 --jsx=automatic --watch",
    "watch:widget": "node scripts/watch-widget.mjs",
    "start": "node lib/",
    "clean": "shx rm -rf lib/",
    "test": "NODE_ENV=test mocha"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.13.1",
  "dependencies": {
    "@athelas/encryption": "workspace:*",
    "@athelas/kyc-utils": "workspace:*",
    "@feathersjs/authentication": "^4.5.18",
    "@feathersjs/configuration": "^4.5.17",
    "@feathersjs/errors": "^4.5.17",
    "@feathersjs/express": "^4.5.18",
    "@feathersjs/feathers": "^4.5.17",
    "@feathersjs/socketio": "^4.5.18",
    "@feathersjs/transport-commons": "^4.5.17",
    "@napi-rs/canvas": "^0.1.96",
    "@types/geoip-lite": "^1.4.4",
    "axios": "1.7.7",
    "cors": "^2.8.5",
    "dayjs": "^1.11.13",
    "dotenv": "^16.4.5",
    "exifr": "^7.1.3",
    "express": "^4.17.2",
    "face-api.js": "^0.22.2",
    "feathers-hooks-common": "^6.1.5",
    "feathers-sequelize": "^6.4.0",
    "form-data": "^4.0.3",
    "geoip-lite": "^2.0.1",
    "helmet": "^5.1.1",
    "mrz": "^5.0.2",
    "multer": "^2.0.2",
    "pg": "^8.13.1",
    "pug": "^3.0.3",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sequelize": "^6.37.5",
    "tesseract.js": "^7.0.0",
    "winston": "^3.16.0",
    "zxing-wasm": "^3.0.1"
  },
  "devDependencies": {
    "@feathersjs/authentication-client": "^4.5.18",
    "@feathersjs/rest-client": "^4.5.17",
    "@tailwindcss/cli": "^4.2.1",
    "@types/cors": "^2.8.17",
    "@types/mocha": "^10.0.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.9.0",
    "@types/pug": "^2.0.10",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "concurrently": "^9.1.2",
    "esbuild": "^0.25",
    "mocha": "^10.7.3",
    "shx": "^0.3.4",
    "source-map-support": "^0.5.21",
    "tailwindcss": "^4.2.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3"
  }
}
