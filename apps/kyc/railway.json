{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "aptPackages": ["build-essential", "libcairo2-dev", "libpango1.0-dev", "libjpeg-dev", "libgif-dev", "librsvg2-dev"],
    "installCommand": "pnpm install",
    "buildCommand": "pnpm --filter athelas-kyc... build",
    "watchPatterns": ["apps/kyc/**"]
  },
  "deploy": {
    "startCommand": "pnpm --filter athelas-kyc start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
