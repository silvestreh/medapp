{
  "name": "athelas",
  "private": true,
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --parallel --filter='!@athelas/face-compare' dev",
    "dev:face-compare": "docker build -t face-compare apps/face-compare && docker run --rm -p 8000:8000 --add-host=host.docker.internal:host-gateway --env-file apps/face-compare/.env face-compare",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "clean": "pnpm -r clean"
  },
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "pnpm": {
    "overrides": {
      "axios": "1.7.7"
    }
  }
}
